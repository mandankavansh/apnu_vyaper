<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base diagonal gradient: deep teal primary to darker teal -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="160"
                android:startColor="#0A8080"
                android:centerColor="@color/colorPrimary"
                android:endColor="@color/colorPrimaryDark" />
        </shape>
    </item>

    <!-- Saffron accent blob top-right -->
    <item
        android:gravity="top|end"
        android:right="-80dp"
        android:top="-100dp">
        <shape android:shape="oval">
            <size
                android:width="240dp"
                android:height="240dp" />
            <solid android:color="#18F5A623" />
        </shape>
    </item>

    <!-- White circle bottom-left (subtle) -->
    <item
        android:gravity="bottom|start"
        android:left="-100dp"
        android:bottom="-120dp">
        <shape android:shape="oval">
            <size
                android:width="300dp"
                android:height="300dp" />
            <solid android:color="#10FFFFFF" />
        </shape>
    </item>

    <!-- Subtle horizontal glow band behind logo area -->
    <item
        android:gravity="center_vertical"
        android:top="90dp"
        android:bottom="150dp">
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00FFFFFF"
                android:centerColor="#0AFFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

</layer-list>
