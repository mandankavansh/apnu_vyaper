<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Gradient using app primary palette -->
    <item>
        <shape>
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="@color/colorPrimaryLight"
                android:centerColor="@color/colorPrimaryMedium"

                android:endColor="@color/colorPrimary"/>
        </shape>
    </item>

    <!-- Very subtle overlay to soften and match UI style -->
    <item>
        <shape>
            <!-- 10% white overlay to keep it soft and professional -->
            <solid android:color="#1AFFFFFF" />
            <corners android:radius="0dp" />
        </shape>
    </item>

</layer-list>
