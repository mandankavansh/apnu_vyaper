<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@color/premium_bg"
    android:clipToPadding="false"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="28dp">

        <!-- ══ Drag Handle ══ -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_sheet_handle" />

        <!-- ══ Header ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:layout_marginBottom="4dp">

            <!-- Teal icon badge -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1E39A99C">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_filter_list_24"
                    app:tint="@color/colorPrimary" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPriceFilterTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Price filter"
                    android:textColor="@color/premium_text_main"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Refine results by budget"
                    android:textColor="@color/premium_text_sub"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══ Preset Range Card ══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/colorSurface"
            app:strokeWidth="1dp"
            app:strokeColor="#14222222">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick ranges"
                    android:textColor="@color/premium_text_sub"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />

                <!-- Preset budget chips -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="false"
                    app:chipSpacingHorizontal="6dp"
                    app:chipSpacingVertical="4dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPriceAll"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="All"
                        android:checked="true"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:chipCornerRadius="18dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPriceUnder1k"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Under ₹1,000"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:chipCornerRadius="18dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPriceUnder5k"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Under ₹5,000"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:chipCornerRadius="18dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrice5kTo20k"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="₹5K – ₹20K"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:chipCornerRadius="18dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrice20kTo50k"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="₹20K – ₹50K"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:chipCornerRadius="18dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrice50kPlus"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="₹50,000+"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:chipCornerRadius="18dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPriceCustom"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Custom"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:chipCornerRadius="18dp"
                        app:chipIcon="@drawable/ic_edit_24"
                        app:chipIconVisible="true"
                        app:chipIconTint="@color/colorPrimary"
                        app:chipIconSize="15dp" />

                </com.google.android.material.chip.ChipGroup>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ Custom Price Range Card (shown only when Custom chip selected) ══ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layoutCustomPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/colorSurface"
            app:strokeWidth="1dp"
            app:strokeColor="#14222222">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CUSTOM RANGE"
                    android:textColor="@color/colorPrimary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.10"
                    android:layout_marginBottom="14dp" />

                <!-- Minimum Price -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Minimum price"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="@android:color/transparent"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxStrokeColor="@color/colorPrimary"
                    app:boxStrokeWidth="1.5dp"
                    app:hintTextColor="@color/premium_text_sub"
                    app:prefixText="₹ "
                    app:prefixTextColor="@color/colorPrimary"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMinPrice"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="numberDecimal"
                        android:maxLength="10"
                        android:textColor="@color/premium_text_main"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:imeOptions="actionNext" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Separator row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#20000000" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:text="to"
                        android:textColor="@color/premium_text_sub"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#20000000" />

                </LinearLayout>

                <!-- Maximum Price -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Maximum price"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="@android:color/transparent"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxStrokeColor="@color/colorPrimary"
                    app:boxStrokeWidth="1.5dp"
                    app:hintTextColor="@color/premium_text_sub"
                    app:prefixText="₹ "
                    app:prefixTextColor="@color/colorPrimary"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMaxPrice"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="numberDecimal"
                        android:maxLength="10"
                        android:textColor="@color/premium_text_main"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:imeOptions="actionDone" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ Bottom Buttons ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearPriceFilter"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Clear"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                app:cornerRadius="18dp"
                app:strokeColor="@color/colorPrimary"
                app:strokeWidth="1.5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApplyPriceFilter"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                android:layout_weight="2"
                android:text="Apply filter"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                app:cornerRadius="18dp"
                app:backgroundTint="@color/colorPrimary"
                app:elevation="0dp"
                app:icon="@drawable/ic_filter_list_24"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:iconPadding="6dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
