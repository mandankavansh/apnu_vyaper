<?xml version="1.0" encoding="utf-8"?>
<!--  item_form_checkbox.xml — Single boolean checkbox field  -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="6dp"
    android:paddingBottom="2dp">

    <!-- Label -->
    <TextView
        android:id="@+id/tvLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Accept Terms"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/colorTextPrimary"
        android:fontFamily="sans-serif-medium"
        android:paddingBottom="8dp" />

    <!-- Checkbox row container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/colorSurfaceVariant"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp">

        <androidx.appcompat.widget.AppCompatCheckBox
            android:id="@+id/cb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text=""
            app:buttonTint="@color/checkbox_tint" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="You must accept terms to continue"
            android:textColor="@color/colorTextPrimary"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.3" />

    </LinearLayout>

</LinearLayout>
