<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="130dp"
    android:layout_margin="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/colorSurface"
    app:cardCornerRadius="22dp"
    app:cardElevation="5dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/colorBorder">

    <FrameLayout
        android:id="@+id/iconContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Full-cover category image -->
        <ImageView
            android:id="@+id/imgIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_placeholder_circle"
            android:background="#E0EFF4" />

        <!-- Soft darkness overlay for readability -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#18000000" />

        <!-- Bottom gradient fade for label contrast -->
        <View
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_cat_bottom_fade" />

        <!-- Selection check badge (top-right, hidden by default) -->
        <FrameLayout
            android:id="@+id/badge"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="9dp"
            android:layout_marginEnd="9dp"
            android:visibility="gone"
            android:background="@drawable/bg_check_badge_premium">

            <ImageView
                android:id="@+id/ivTick"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="3dp"
                android:src="@drawable/ic_check_24"
                app:tint="@android:color/white" />
        </FrameLayout>

        <!-- Category label pill (frosted glass, bottom center) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="10dp"
            android:minWidth="80dp"
            app:cardBackgroundColor="#E6FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#30FFFFFF">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:minWidth="80dp"
                android:gravity="center"
                android:text="Category"
                android:textAlignment="center"
                android:textColor="@color/colorPrimaryDark"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:maxLines="1"
                android:ellipsize="end" />

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>