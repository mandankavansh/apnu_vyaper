<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="196dp"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="20dp"
    android:gravity="center_vertical"
    android:background="@drawable/nav_header_bg"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackgroundBorderless">

    <!-- Saffron accent bar at top -->
    <View
        android:layout_width="36dp"
        android:layout_height="3dp"
        android:layout_marginBottom="16dp"
        android:background="@color/colorSecondary"
        android:layout_gravity="start" />

    <!-- Profile row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Avatar circle with white border -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp"
            app:strokeWidth="2dp"
            app:strokeColor="#60FFFFFF"
            app:cardBackgroundColor="@android:color/transparent">

            <ImageView
                android:id="@+id/ivProfile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_person_24px"
                android:padding="14dp"
                app:tint="@color/white"
                android:contentDescription="@null" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="User"
                android:textSize="19sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/white"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvUserPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="+91 00000 00000"
                android:textSize="13sp"
                android:textColor="#CCFFFFFF"
                android:fontFamily="sans-serif"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvUserTagline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="apnuvyapar · SMART. SIMPLE."
                android:textSize="10sp"
                android:textColor="@color/colorSecondary"
                android:fontFamily="sans-serif"
                android:layout_marginTop="6dp"
                android:letterSpacing="0.05"
                android:textAllCaps="true" />
        </LinearLayout>

        <!-- Edit profile icon -->
        <ImageView
            android:id="@+id/ivEdit"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_edit_24"
            app:tint="@color/colorSecondary"
            android:contentDescription="@null"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:alpha="0.9" />
    </LinearLayout>

</LinearLayout>
