<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLogin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="top"
            android:paddingStart="@dimen/page_hpad"
            android:paddingEnd="@dimen/page_hpad"
            android:paddingTop="@dimen/page_vpad"
            android:paddingBottom="120dp">

            <!-- Language badge -->
<!--            <TextView-->
<!--                android:id="@+id/tvLangBadge"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:text="@string/badge_language"-->
<!--                android:textStyle="bold"-->
<!--                android:textColor="@android:color/white"-->
<!--                android:background="#331F2933"-->
<!--                android:paddingStart="10dp"-->
<!--                android:paddingEnd="10dp"-->
<!--                android:paddingTop="4dp"-->
<!--                android:paddingBottom="4dp"-->
<!--                android:textSize="11sp"-->
<!--                android:layout_marginBottom="10dp"-->
<!--                android:letterSpacing="0.03" />-->

            <!-- Header -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/title_login"
                android:textSize="@dimen/title_text"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:letterSpacing="0.02"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="4dp"/>

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/login_subtitle"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="16dp" />

            <!-- Glass Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="10dp"
                app:cardCornerRadius="22dp"
                app:cardBackgroundColor="#CCF9FAFB">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/panel_pad">

                    <!-- Section title -->
                    <TextView
                        android:id="@+id/tvSectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/login_section_title"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="@color/ss_on_surface"
                        android:layout_marginBottom="12dp" />

                    <!-- Mobile -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_mobile"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxBackgroundColor="@android:color/white"
                        app:hintTextColor="@color/ss_hint"
                        app:startIconDrawable="@drawable/ic_phone">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMobile"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:inputType="phone"
                            android:maxLength="10"
                            android:textColor="@android:color/black"
                            android:textSize="14sp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Helper -->
                    <TextView
                        android:id="@+id/tvHelper"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/login_mobile_helper"
                        android:textColor="@color/ss_hint"
                        android:textSize="11sp"
                        android:layout_marginTop="6dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Register link -->
            <TextView
                android:id="@+id/tvGoRegister"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/cta_register"
                android:gravity="center"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="@android:color/white"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky CTA -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSendOtp"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="18dp"
        android:text="@string/btn_send_otp"
        android:textAllCaps="false"
        android:backgroundTint="@color/brand_green"
        android:textColor="@android:color/white"
        app:cornerRadius="18dp"
        app:rippleColor="@color/ss_ripple_light"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
