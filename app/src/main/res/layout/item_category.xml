<?xml version="1.0" encoding="utf-8"?>
<!--
    CATEGORY ITEM — Portrait card (tall, narrow)
    Used in horizontal RecyclerView at top of Select Category screen.
    Identity: Teal top accent bar + large image + frosted pill label.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackgroundBorderless">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/catCard"
        android:layout_width="100dp"
        android:layout_height="120dp"
        android:clickable="false"
        android:focusable="false"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="20dp"

        app:strokeWidth="2dp"
        app:strokeColor="@color/colorBorder">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Full-bleed category image -->
            <ImageView
                android:id="@+id/catIcon"
                android:layout_width="match_parent"
                android:layout_gravity="center"
                android:layout_height="115dp"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_all_listings"
                android:background="#EBF4F4" />

            <!-- Gradient scrim — bottom 60dp -->
            <View
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_bottom_scrim" />

            <!-- ━━ TEAL TOP ACCENT BAR — marks it as a CATEGORY ━━ -->


            <!-- Saffron selection badge — top right -->
            <FrameLayout
                android:id="@+id/badge"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="8dp"
                android:visibility="gone"
                android:background="@drawable/bg_check_badge_premium"
                android:elevation="6dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="6dp"
                    android:src="@drawable/ic_check_24"
                    app:tint="@android:color/white" />

            </FrameLayout>

            <!-- Frosted pill label — bottom center -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="8dp"
                android:minWidth="76dp"
                app:cardBackgroundColor="#E6FFFFFF"
                app:cardCornerRadius="15dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <TextView
                    android:id="@+id/catTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:minWidth="76dp"
                    android:gravity="center"
                    android:text="Category"
                    android:textAlignment="center"
                    android:textColor="#1A2332"
                    android:textSize="11.5sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>