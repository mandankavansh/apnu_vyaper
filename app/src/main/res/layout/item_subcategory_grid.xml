<?xml version="1.0" encoding="utf-8"?>
<!--
    SUBCATEGORY GRID ITEM — Same portrait card style as Category
    Difference: no teal top bar. Saffron badge for selection.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="130dp"
    android:layout_margin="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/colorBorder">

    <FrameLayout
        android:id="@+id/iconContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Full-bleed subcategory image -->
        <ImageView
            android:id="@+id/imgIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_placeholder_circle"
            android:background="@color/colorSurfaceVariant" />

        <!-- Soft overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#10000000" />

        <!-- Bottom gradient scrim -->
        <View
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_bottom_scrim" />

        <!-- ━━ SAFFRON SELECTION BADGE — top right, always visible ━━ -->
        <FrameLayout
            android:id="@+id/badge"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone"
            android:background="@drawable/bg_check_badge_premium"
            android:elevation="6dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="6dp"
                android:src="@drawable/ic_check_24"
                app:tint="@android:color/white" />

        </FrameLayout>

        <!-- Frosted pill label — bottom center -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:minWidth="82dp"
            app:cardBackgroundColor="#E6FFFFFF"
            app:cardCornerRadius="17dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:minWidth="82dp"
                android:gravity="center"
                android:text="Subcategory"
                android:textAlignment="center"
                android:textColor="#1A2332"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:maxLines="1"
                android:ellipsize="end" />

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>